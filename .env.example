# Copy this file to `.env` in the project root for backend development.
# Frontend development variables should be configured in `frontend/.env.development`.

# ====================
# Flask environment
# ====================
FLASK_ENV=development

# ====================
# Security
# ====================
# Generate strong random values for production:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production

# ====================
# Database
# ====================
# Development environment reads DEV_DATABASE_URL.
# If omitted, backend will fall back to:
# postgresql://postgres:123456@localhost:5432/learning_analytics_system
DEV_DATABASE_URL=postgresql://postgres:123456@localhost:5432/learning_analytics_system

# Production environment reads DATABASE_URL.
# DATABASE_URL=postgresql://username:password@localhost:5432/learning_analytics_system

# ====================
# CORS
# ====================
# Separate multiple origins with commas.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:3000,http://localhost:3000

# ====================
# Uploads
# ====================
# Relative paths are resolved under `backend/`.
UPLOAD_FOLDER=uploads
MAX_UPLOAD_SIZE_MB=64

# ====================
# Logging
# ====================
LOG_LEVEL=INFO

# ====================
# AI planner / Qwen
# ====================
# You can use either QWEN_API_KEY or DASHSCOPE_API_KEY.
QWEN_API_KEY=
# DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus-2025-07-28
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_ENABLE_FALLBACK=1
AI_MAX_RETRIES=2
AI_RETRY_BACKOFF=1.25

# ====================
# Monitoring
# ====================
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

